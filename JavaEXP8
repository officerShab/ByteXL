package com.example.web;

import com.example.db.DbUtil;

import javax.servlet.ServletContextEvent;
import javax.servlet.ServletContextListener;
import javax.servlet.annotation.WebListener;
import java.sql.Connection;
import java.sql.Statement;

@WebListener
public class AppInitListener implements ServletContextListener {
    @Override
    public void contextInitialized(ServletContextEvent sce) {
        try (Connection conn = DbUtil.getConnection();
             Statement st = conn.createStatement()) {
            // Users table for login (Part A)
            st.execute("""
                CREATE TABLE IF NOT EXISTS users(
                  id IDENTITY PRIMARY KEY,
                  username VARCHAR(50) UNIQUE NOT NULL,
                  password VARCHAR(100) NOT NULL,
                  fullname VARCHAR(100) NOT NULL
                )
            """);
            st.execute("""
                MERGE INTO users KEY(username)
                VALUES (1,'admin','admin123','Administrator'),
                       (2,'alice','alice123','Alice Johnson'),
                       (3,'bob','bob123','Bob Singh')
            """);

            // Employees table for Part B
            st.execute("""
                CREATE TABLE IF NOT EXISTS employees(
                  id IDENTITY PRIMARY KEY,
                  name VARCHAR(100) NOT NULL,
                  department VARCHAR(80),
                  salary DECIMAL(10,2)
                )
            """);
            st.execute("""
                MERGE INTO employees KEY(id)
                VALUES (1,'Ravi Kumar','IT',75000.00),
                       (2,'Neha Sharma','HR',62000.00),
                       (3,'Arjun Mehta','Finance',83000.00)
            """);

            // Students & Attendance tables for Part C
            st.execute("""
                CREATE TABLE IF NOT EXISTS students(
                  id IDENTITY PRIMARY KEY,
                  roll_no VARCHAR(20) UNIQUE NOT NULL,
                  name VARCHAR(100) NOT NULL
                )
            """);
            st.execute("""
                MERGE INTO students KEY(roll_no)
                VALUES (1,'CS101','Sana Khan'),
                       (2,'CS102','Vikram Patel'),
                       (3,'CS103','Ananya Rao')
            """);
            st.execute("""
                CREATE TABLE IF NOT EXISTS attendance(
                  id IDENTITY PRIMARY KEY,
                  roll_no VARCHAR(20) NOT NULL,
                  date VARCHAR(20) NOT NULL,
                  status VARCHAR(10) NOT NULL,
                  CONSTRAINT fk_att_student FOREIGN KEY (roll_no) REFERENCES students(roll_no)
                )
            """);
        } catch (Exception e) {
            throw new RuntimeException("Failed to initialize schema", e);
        }
    }
}

