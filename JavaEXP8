<%@ page contentType="text/html;charset=UTF-8" %>
<%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %>
<!doctype html>
<html>
<head>
  <title>Student Attendance</title>
  <style>
    body{font-family:sans-serif;margin:2rem}
    form{display:grid;gap:.6rem;max-width:420px}
    select,input,button{padding:.5rem}
    table{border-collapse:collapse;margin-top:1rem}
    td,th{border:1px solid #999;padding:6px 10px}
    .row{display:flex;gap:1rem;flex-wrap:wrap}
    a{color:#036}
  </style>
</head>
<body>
  <h2>Student Attendance Portal (JSP + Servlet)</h2>
  <p><a href="index.html">&larr; Home</a></p>

  <div class="row">
    <!-- Mark Attendance -->
    <div>
      <h3>Mark Attendance</h3>
      <form action="attendance" method="post">
        <label>Roll No</label>
        <select name="rollNo" required>
          <c:forEach var="r" items="${students}">
            <option value="${r}">${r}</option>
          </c:forEach>
        </select>

        <label>Date (YYYY-MM-DD)</label>
        <input name="date" type="text" placeholder="2025-11-06" required>

        <label>Status</label>
        <select name="status" required>
          <option value="PRESENT">PRESENT</option>
          <option value="ABSENT">ABSENT</option>
          <option value="LATE">LATE</option>
        </select>

        <button type="submit">Save</button>
      </form>
    </div>

    <!-- View Attendance -->
    <div>
      <h3>View Attendance By Date</h3>
      <form action="attendance" method="get">
        <label>Date (YYYY-MM-DD)</label>
        <input name="date" type="text" value="${date != null ? date : ''}" required>
        <button type="submit">Load</button>
      </form>

      <c:if test="${not empty records}">
        <table>
          <tr><th>ID</th><th>Roll No</th><th>Date</th><th>Status</th></tr>
          <c:forEach var="rec" items="${records}">
            <tr>
              <td>${rec.id}</td>
              <td>${rec.rollNo}</td>
              <td>${rec.date}</td>
              <td>${rec.status}</td>
            </tr>
          </c:forEach>
        </table>
      </c:if>
    </div>
  </div>
</body>
</html>
