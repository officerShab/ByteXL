package com.example.dao;

import com.example.db.DbUtil;

import java.sql.*;
import java.util.ArrayList;
import java.util.List;

public class EmployeeDAO {
    public static class Employee {
        public long id;
        public String name;
        public String department;
        public double salary;
    }

    public List<Employee> findAll() {
        List<Employee> list = new ArrayList<>();
        String sql = "SELECT id,name,department,salary FROM employees ORDER BY id";
        try (Connection conn = DbUtil.getConnection();
             Statement st = conn.createStatement();
             ResultSet rs = st.executeQuery(sql)) {
            while (rs.next()) {
                Employee e = new Employee();
                e.id = rs.getLong("id");
                e.name = rs.getString("name");
                e.department = rs.getString("department");
                e.salary = rs.getDouble("salary");
                list.add(e);
            }
        } catch (Exception e) {
            throw new RuntimeException("Fetch employees failed", e);
        }
        return list;
    }
}

