package partb;

import partb.dao.StudentDAO;
import partb.entity.Student;
import partb.util.HibernateUtil;

public class MainCRUD {
    public static void main(String[] args) {
        StudentDAO dao = new StudentDAO();

        Long id1 = dao.save(new Student("Alice", 20, "alice@example.com"));
        Long id2 = dao.save(new Student("Bob", 22, "bob@example.com"));

        System.out.println("All: " + dao.findAll());

        var s1 = dao.findById(id1).orElseThrow();
        s1.setAge(21);
        dao.update(s1);
        System.out.println("Updated: " + dao.findById(id1).orElseThrow());

        dao.delete(id2);
        System.out.println("After delete: " + dao.findAll());

        HibernateUtil.shutdown();
    }
}


