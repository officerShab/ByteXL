package partc;

import org.springframework.context.annotation.AnnotationConfigApplicationContext;
import partc.config.PersistenceConfig;
import partc.entity.Student;
import partc.service.StudentService;

public class MainTx {
    public static void main(String[] args) {
        try (var ctx = new AnnotationConfigApplicationContext(PersistenceConfig.class)) {
            var svc = ctx.getBean(StudentService.class);

            Long id1 = svc.create(new Student("Carol", 23, "carol@example.com"));
            Long id2 = svc.create(new Student("Dave", 24, "dave@example.com"));
            System.out.println("Initial: " + svc.list());

            svc.updateEmail(id1, "carol@uni.edu");
            System.out.println("After email update: " + svc.list());

            try {
                svc.batchCreateWithRollback(
                    new Student("Eve", 22, "eve@example.com"),
                    new Student("Frank", 25, "frank@example.com")
                );
            } catch (RuntimeException ex) {
                System.out.println("Caught: " + ex.getMessage());
            }
            System.out.println("After forced rollback (no Eve/Frank): " + svc.list());

            svc.delete(id2);
            System.out.println("After delete Dave: " + svc.list());
        }
    }
}





