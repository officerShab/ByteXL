package partc.service;

import org.springframework.stereotype.Service;
import org.springframework.transaction.annotation.Transactional;
import partc.dao.StudentRepository;
import partc.entity.Student;

import java.util.List;

@Service
public class StudentService {
    private final StudentRepository repo;
    public StudentService(StudentRepository repo) { this.repo = repo; }

    @Transactional(readOnly = true)
    public List<Student> list() { return repo.findAll(); }

    @Transactional
    public Long create(Student s) { return repo.save(s); }

    @Transactional
    public void updateEmail(Long id, String newEmail) {
        var s = repo.findById(id).orElseThrow();
        s.setEmail(newEmail);
        repo.update(s);
    }

    // Demonstrates rollback on runtime exception
    @Transactional
    public void batchCreateWithRollback(Student a, Student b) {
        repo.save(a);
        if (true) throw new RuntimeException("Forcing rollback");
        // repo.save(b);
    }

    @Transactional
    public void delete(Long id) { repo.delete(id); }
}

